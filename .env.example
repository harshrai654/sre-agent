# Slack App Credentials
# Get these from https://api.slack.com/apps after creating your app

# Bot User OAuth Token (starts with xoxb-)
# Found at: OAuth & Permissions > OAuth Tokens for Your Workspace
SLACK_BOT_TOKEN=

# App-Level Token (starts with xapp-)
# Found at: Basic Information > App-Level Tokens (after enabling Socket Mode)
SLACK_APP_TOKEN=

# Logging
# Use `debug` to include the full agent conversation transcript in logs (see harness `Agent conversation transcript`).
LOG_LEVEL=info

# Grafana MCP Server Configuration
# Required for fetching live alert state
# Example: http://localhost:3000/mcp or https://grafana.example.com/mcp
GRAFANA_MCP_URL=

# Optional: extra HTTP headers for MCP (e.g. Cloudflare Access service tokens in dev).
# JSON (recommended): {"CF-Access-Client-Id":"...","CF-Access-Client-Secret":"..."}
# Or comma-separated: CF-Access-Client-Id: xxx, CF-Access-Client-Secret: yyy
# GRAFANA_MCP_HEADERS=

# Deep agent harness (importing the harness module validates these at startup)
# OpenAI chat model id, e.g. gpt-4o, gpt-4o-mini
LLM_MODEL=
OPENAI_API_KEY=

# Optional: supplementary AGENTS.md (appended to built-in instructions from src/templates/system-instructions.md).
# Do not point this at system-instructions.md — that file is loaded automatically. Omit in most setups.
# Mount as ConfigMap/Secret in Kubernetes for hot-reload support
# AGENTS_MD_PATH=/etc/sre-agent/AGENTS.md
